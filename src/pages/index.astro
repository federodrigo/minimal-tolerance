---
import "../styles/global.css";

const ssrnUrl =
  "https://papers.ssrn.com/sol3/papers.cfm?abstract_id=TU_ID";
---

<!doctype html>

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>Minimal Tolerance</title>

    <meta
      name="description"
      content="A theory of minimal tolerance exploring coercion, political authority, and the limits of tolerable power."
    />
  </head>

  <body>
    <header class="site-header">
      <a href="/" class="logo">
        Minimal Tolerance
      </a>

      <nav aria-label="Main navigation">
        <a href="#theorem">Theory</a>
        <a href="#book">Book</a>

        <a
          href={ssrnUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          Paper
        </a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-content">
          <p class="eyebrow">
            Minimal Tolerance
          </p>

          <h1>
            A Theory of
            <span>Minimal Tolerance</span>
          </h1>

          <p class="lead">
            The question is not whether power is legitimate.
            The question is how much power can be tolerated.
          </p>

          <div
            class="animated-text"
            aria-label="Power is not legitimized. Power is tolerated only under exceptional conditions."
          >
            <span>Power is not legitimized.</span>
            <span>Power is tolerated.</span>
            <span>Only under exceptional conditions.</span>
          </div>

          <div class="buttons">
            <a
              href={ssrnUrl}
              class="primary"
              target="_blank"
              rel="noopener noreferrer"
            >
              Read the SSRN Paper
            </a>

            <a href="#theorem" class="secondary">
              Explore the Theory
            </a>
          </div>
        </div>
      </section>

      <section class="statement">
        <blockquote>
          Not every important problem justifies coercion.
        </blockquote>
      </section>

      <section id="theorem" class="theorem">
        <div class="container">
          <h2>The Minimal Tolerance Theorem</h2>

          <p>
            The State can only be tolerated if all necessary conditions
            are met simultaneously. If even one condition fails,
            coercion is prohibited.
          </p>

          <img
            src="/images/theorem.png"
            alt="Diagram explaining the conditions of the Minimal Tolerance Theorem"
            loading="lazy"
          />
        </div>
      </section>

      <section id="book" class="book">
        <div class="container">
          <div class="book-grid">
            <div class="book-cover">
              <img
                src="/images/book-cover.jpg"
                alt="Cover of Power, Tolerance and Legitimacy by Federico Rodrigo"
                loading="lazy"
              />
            </div>

            <div class="book-content">
              <p class="eyebrow">
                The Book
              </p>

              <h2>
                Power, Tolerance and Legitimacy
              </h2>

              <p>
                A philosophical and institutional framework for
                understanding coercion, political authority, and the
                limits of tolerable power.
              </p>

              <a
                href={ssrnUrl}
                class="secondary"
                target="_blank"
                rel="noopener noreferrer"
              >
                Read the Foundational Paper
              </a>
            </div>
          </div>
        </div>
      </section>

      <section class="ssrn">
        <div class="container">
          <p class="eyebrow">
            Original Research
          </p>

          <h2>Read the Original Paper</h2>

          <p>
            Explore the complete formulation of the theory,
            its conditions, and its implications.
          </p>

          <a
            href={ssrnUrl}
            class="primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Read on SSRN
          </a>
        </div>
      </section>
    </main>

    <footer>
      <p>
        © 2026 Minimal Tolerance · Federico Rodrigo
      </p>
    </footer>
  </body>
</html>
