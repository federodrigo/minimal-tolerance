---
import "../styles/global.css";

const ssrnUrl =
  "https://papers.ssrn.com/sol3/papers.cfm?abstract_id=5984574";
---

<!doctype html>

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>Minimal Tolerance</title>

    <meta
      name="description"
      content="A theory of minimal tolerance exploring coercion, political authority, and the limits of tolerable power."
    />
  </head>

  <body>

    <header class="site-header">

      <a href="/" class="logo">
        Minimal Tolerance
      </a>

      <nav>
        <a href="#theorem">Theory</a>
        <a href="#book">Book</a>
        <a href="#paper">Paper</a>
      </nav>

    </header>

    <main>

      <section class="hero">

        <div class="hero-content">

          <p class="eyebrow">
  POWER, COERCION AND POLITICAL AUTHORITY
</p>

<h1>
  Minimal Tolerance
  <span>A Theory of Tolerable Power</span>
</h1>

          <p class="lead">
            The question is not whether power is legitimate.
            The question is how much power can be tolerated.
          </p>

          <div class="animated-text">
            <span>Power is tolerated.</span>
            <span>Not legitimized.</span>
            <span>Only under exceptional conditions.</span>
          </div>

          <div class="buttons">

            <a href="#theorem" class="primary">
              Explore the Theory
            </a>

            <a href="#paper" class="secondary">
              Read the Paper
            </a>

          </div>

        </div>

      </section>

      <section class="statement">

        <blockquote>
          Not every important problem justifies coercion.
        </blockquote>

      </section>

      <section id="theorem" class="theorem">

        <div class="container">

          <p class="eyebrow">
            THE THEORY
          </p>

          <h2>
            The Minimal Tolerance Theorem
          </h2>

          <p>
            The State can only be tolerated when a strict set of
            conditions is simultaneously satisfied. If even one
            condition fails, coercion is prohibited.
          </p>

          <img
            src="/images/theorem.png"
            alt="Minimal Tolerance Theorem"
          />

        </div>

      </section>

      <section id="book" class="book">

        <div class="container">

          <div class="book-grid">

            <div>

              <img
                src="/images/book-cover.jpg"
                alt="Power, Tolerance and Legitimacy"
              />

            </div>

            <div>

              <p class="eyebrow">
                THE BOOK
              </p>

              <h2>
                Power, Tolerance and Legitimacy
              </h2>

              <p>
                A philosophical framework for understanding
                coercion, public goods, free riders,
                political authority, and the limits of
                tolerable power.
              </p>

            </div>

          </div>

        </div>

      </section>

      <section id="paper" class="ssrn">

        <div class="container">

          <p class="eyebrow">
  POWER, COERCION AND POLITICAL AUTHORITY
</p>

          <h2>
            Read the Foundational Paper
          </h2>

          <p>
            Explore the complete formulation of the theory,
            its assumptions, its conditions, and its implications.
          </p>

          <a
            href={ssrnUrl}
            class="primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Open on SSRN
          </a>

        </div>

      </section>

    </main>

    <footer>

      <p>
        © 2026 Minimal Tolerance · Federico Rodrigo
      </p>

    </footer>

  </body>

</html>
