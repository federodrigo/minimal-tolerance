---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const ssrnUrl =
  "https://papers.ssrn.com/sol3/papers.cfm?abstract_id=5984574";
---

<!doctype html>

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>
      When May Coercion Be Tolerated? | Minimal Tolerance
    </title>

    <meta
      name="description"
      content="Minimal Tolerance is a theory of power and legitimacy that asks under what exceptional conditions state coercion may be tolerated"
    />
  </head>

  <body>

    <Header />

    <main>

      <!-- HERO -->

      <section class="hero">

        <div class="hero-content">

          <p class="eyebrow">
            THE THEORY OF MINIMAL TOLERANCE
          </p>

          <h1>
            When may coercion<br />
            be tolerated?
          </h1>

          <p class="lead">
            A theory of power and legitimacy
          </p>

          <div
            class="animated-text"
            aria-label="Power is tolerated. Not legitimized. Only under exceptional conditions"
          >
            <span>Power is tolerated</span>
            <span>Not legitimized</span>
            <span>Only under exceptional conditions</span>
          </div>

          <div class="buttons">

            <a href="/theory" class="primary">
              Explore the Theory
            </a>

            <a
              href={ssrnUrl}
              class="secondary"
              target="_blank"
              rel="noopener noreferrer"
            >
              Read the Paper
            </a>

          </div>

        </div>

      </section>

      <!-- CENTRAL STATEMENT -->

      <section class="statement">

        <blockquote>
          The State may be tolerated only as an institutional
          technology of last resort
        </blockquote>

      </section>

      <!-- THEORY -->

      <section id="theory" class="content-section">

        <div class="container">

          <p class="eyebrow">
            THE THEORY
          </p>

          <h2>
            Foundations
          </h2>

          <div class="foundation-principles">

            <article class="foundation-principle">

              <span class="foundation-number">
                01
              </span>

              <div>

                <h3>
                  No intrinsic moral legitimacy
                </h3>

                <p>
                  The State possesses no moral authority merely by
                  existing or by exercising power
                </p>

              </div>

            </article>

            <article class="foundation-principle">

              <span class="foundation-number">
                02
              </span>

              <div>

                <h3>
                  Institutional limits remain unavoidable
                </h3>

                <p>
                  State action is constrained by informational and
                  economic limitations that power cannot eliminate
                </p>

              </div>

            </article>

          </div>

          <a href="/theory" class="secondary">
            Continue Reading
          </a>

        </div>

      </section>

      <!-- THEOREM -->

      <section id="theorem" class="theorem">

        <div class="container">

          <p class="eyebrow">
            THE FORMAL TEST
          </p>

          <h2>
            The Minimal Tolerance Theorem
          </h2>

          <p>
            Coercion may be considered only when three conditions
            are simultaneously satisfied
          </p>

          <div class="theorem-summary">

            <span>
              Effective non-excludability
            </span>

            <span>
              Relevant non-rivalry
            </span>

            <span>
              Persistent voluntary collapse
            </span>

          </div>

          <div class="buttons">

            <a href="/theorem" class="primary">
              Examine the Theorem
            </a>

          </div>

        </div>

      </section>

      <!-- BOOK -->

      <section id="book" class="book">

        <div class="container">

          <div class="book-grid">

            <div>

              <img
                src="/images/book-cover.jpg"
                alt="Cover of Minimal Tolerance by Federico Rodrigo"
                loading="lazy"
              />

            </div>

            <div>

              <p class="eyebrow">
                THE BOOK
              </p>

              <h2>
                Minimal Tolerance
              </h2>

              <p class="book-subtitle">
                A Theory of Power and Legitimacy
              </p>

              <p>
                A forthcoming book on power, legitimacy and the
                exceptional limits of coercion
              </p>

              <a href="/book" class="secondary">
                Discover the Book
              </a>

            </div>

          </div>

        </div>

      </section>

      <!-- PAPER -->

      <section id="paper" class="ssrn">

        <div class="container">

          <p class="eyebrow">
            SSRN PREPRINT
          </p>

          <h2>
            Read the Foundational Paper
          </h2>

          <p>
            The formal statement of the theorem and the narrow
            conditions under which state coercion may be tolerated
          </p>

          <a
            href={ssrnUrl}
            class="primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Open on SSRN
          </a>

        </div>

      </section>

    </main>

    <Footer />

  </body>
</html>
