.home-links {
  padding: 64px 0;
}

.home-links-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
}

.home-link-card {
  padding: 32px;
  background: var(--paper-light);
  border: 1px solid var(--line);
  border-radius: 14px;
}

.home-link-card h2 {
  font-size: clamp(1.8rem, 3vw, 2.5rem);
}

.home-link-card p {
  max-width: 620px;
  font-size: 1.05rem;
  line-height: 1.65;
}

@media (max-width: 900px) {
  .home-links {
    padding: 50px 0;
  }

  .home-links-grid {
    grid-template-columns: 1fr;
  }
}
