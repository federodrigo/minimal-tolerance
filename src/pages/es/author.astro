---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const ssrnUrl =
  "https://papers.ssrn.com/sol3/papers.cfm?abstract_id=5984574";
---

<!doctype html>

<html lang="es">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>
      Autor | Tolerancia Mínima
    </title>

    <meta
      name="description"
      content="Federico Rodrigo es un autor independiente y ejecutivo de tecnología cuyo trabajo examina la coerción, la autoridad política y los límites del poder estatal."
    />

    <link
      rel="canonical"
      href="https://minimaltolerance.com/author"
    />
  </head>

  <body>

    <Header />

    <main>

      <section class="page-hero">

        <div class="container">

          <p class="eyebrow">
            EL AUTOR
          </p>

          <h1>
            Federico Rodrigo
          </h1>

        </div>

      </section>

      <section class="statement">

        <blockquote>
          Todo argumento debe sobrevivir a su objeción más fuerte
        </blockquote>

      </section>

      <section class="content-section">

        <div class="container">

          <p class="eyebrow">
            ACERCA DE
          </p>

          <h2>
            Autor independiente y ejecutivo de tecnología
          </h2>

          <p>
            Federico "Fede" Rodrigo escribe sobre poder,
            legitimidad y coerción. Su trabajo explora las
            condiciones bajo las cuales la autoridad estatal
            puede ser tolerada
          </p>

          <p>
            La teoría política es un interés personal más que una
            profesión. Fuera de su actividad como autor, trabaja
            en liderazgo tecnológico y gestión ejecutiva
          </p>

        </div>

      </section>

      <section class="content-section content-section-alt">

        <div class="container">

          <p class="eyebrow">
            CONTACTO
          </p>

          <h2>
            Ponte en contacto
          </h2>

          <p>
            Las preguntas, objeciones y críticas son bienvenidas
          </p>

          <p>
            <a href="mailto:fede@minimaltolerance.com">
              fede@minimaltolerance.com
            </a>
          </p>

        </div>

      </section>

      <section class="ssrn">

        <div class="container">

          <p class="eyebrow">
            INVESTIGACIÓN
          </p>

          <h2>
            La Teoría de la Tolerancia Mínima
          </h2>

          <p>
            El artículo fundacional presenta el teorema formal
            y las condiciones bajo las cuales la coerción
            estatal puede ser tolerada
          </p>

          <a
            href={ssrnUrl}
            class="primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Abrir en SSRN
          </a>

        </div>

      </section>

    </main>

    <Footer />

  </body>
</html>
