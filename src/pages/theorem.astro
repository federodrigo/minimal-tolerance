---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>
      The Theorem of Minimal Tolerance | Minimal Tolerance
    </title>

    <meta
      name="description"
      content="The formal statement, necessary conditions, burden of proof and corollary of the Minimal Tolerance Theorem by Federico Rodrigo."
    />

    <link
      rel="canonical"
      href="https://minimaltolerance.com/theorem"
    />
  </head>

  <body>
    <Header />

    <main>

      <!-- PAGE TITLE -->

      <section class="page-hero">

        <div class="container">

          <p class="eyebrow">
            THE FORMAL TEST
          </p>

          <h1>
            Defining the Boundary
          </h1>

        </div>

      </section>

      <!-- MAIN STATEMENT -->

      <section class="statement">

        <blockquote>
          The burden of proof rests entirely with those
          proposing coercion
        </blockquote>

      </section>

      <!-- INSTITUTIONAL LAST RESORT -->

  <section class="content-section content-section-alt">

  <div class="container">

    <p class="eyebrow">
      INSTITUTIONAL LAST RESORT
    </p>

    <h2>
      Defining the exception
    </h2>

<p>
  The State is neither a moral nor an efficient solution.
  Its justification cannot rest on legitimacy, nor on any
  claim of superior performance. Both arguments have
  already failed
</p>

<p>
  Any possible tolerance remains exceptional rather than
  general. The theorem defines a boundary between what
  may be reluctantly tolerated and what must remain
  outside that exception
</p>
 

  </div>

</section>

      <!-- FORMAL STATEMENT -->

      <section class="content-section">

        <div class="container">

          <p class="eyebrow">
            FORMAL STATEMENT
          </p>

          <h2>
            The Theorem of Minimal Tolerance
          </h2>

          <blockquote class="formal-statement">
          State coercion may be tolerated only when a structural
          free-rider problem renders stable voluntary provision
          persistently unviable and non-intervention would
          produce greater harm
          </blockquote>

        </div>

      </section>

      <!-- THREE CONDITIONS -->

      <section class="theorem">

        <div class="container">

          <p class="eyebrow">
            THE THREE CONDITIONS
          </p>

          <h2>
             A Structural free-rider Problem
          </h2>

         <div class="theorem-conditions">

            <article>

              <span>01</span>

              <h3>
                Effective non-excludability
              </h3>

              <p>
                It must be physically, technically or economically
                impossible to exclude non-payers from receiving the
                relevant benefit
              </p>

            </article>

            <article>

              <span>02</span>

              <h3>
                Relevant non-rivalry
              </h3>

              <p>
                One person’s use of the good must not meaningfully
                reduce the amount available to others
              </p>

            </article>

            <article>

              <span>03</span>

              <h3>
                Persistent voluntary collapse
              </h3>

              <p>
                Voluntary provision must remain persistently unviable
                for reasons not caused by removable regulatory or
                legal obstacles
              </p>

            </article>

          </div>

        </div>

      </section>

     <!-- COROLLARY -->

     <section class="content-section">

  <div class="container">

   <p class="eyebrow">
  COROLLARY
</p>

<h2>
  The default remains non-intervention
</h2>

<p>
  Importance, collective benefit or the existence of a
  difficulty does not establish a functional
  justification for coercion
</p>

<p>
  Where no structural free-rider problem exists, state
  intervention lacks functional justification and must
  be presumed illegitimate by default
</p>  

  </div>

</section>

      <!-- APPLICATIONS -->

      <section class="content-section content-section-alt">

        <div class="container">

          <p class="eyebrow">
            APPLICATIONS
          </p>

          <h2>
            Testing the boundary
          </h2>

          <p>
            The theorem matters only if it can distinguish genuine
            institutional necessity from political convenience,
            paternalism and dissatisfaction with voluntary outcomes
          </p>

          <div class="buttons">

            <a href="/applications" class="primary">
              Explore the Applications
            </a>

          </div>

        </div>

      </section>

    </main>

    <Footer />
  </body>
</html>
