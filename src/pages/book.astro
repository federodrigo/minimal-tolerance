---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const ssrnUrl =
  "https://papers.ssrn.com/sol3/papers.cfm?abstract_id=5984574";
---

<!doctype html>

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>
      Power, Tolerance and Legitimacy | Minimal Tolerance
    </title>

    <meta
      name="description"
      content="Power, Tolerance and Legitimacy by Federico Rodrigo examines coercion, political authority and the limits of state power."
    />

    <link
      rel="canonical"
      href="https://minimaltolerance.com/book"
    />
  </head>

  <body>

    <Header />

    <main>

      <section class="page-hero">

        <div class="container">

          <p class="eyebrow">
            THE BOOK
          </p>

          <h1>
            Power, Tolerance and Legitimacy
          </h1>

        </div>

      </section>

      <section class="statement">

        <blockquote>
          The question is not whether coercive power is legitimate.
The question is how much of it can be tolerated
        </blockquote>

      </section>

      <section class="book">

        <div class="container">

          <div class="book-grid">

            <div>

              <img
                src="/images/book-cover.jpg"
                alt="Cover of A Theory of Minimal Tolerance by Federico Rodrigo"
              />

            </div>

            <div>

              <p class="eyebrow">
                ABOUT THE BOOK
              </p>

              <h2>
                A Theory of Power and Legitimacy
              </h2>

              <p>
                Power, Tolerance and Legitimacy develops the moral,
economic and institutional arguments behind the
Theory of Minimal Tolerance. It examines legitimacy,
coercion, public goods, free-rider problems and the
limits of state power
              </p>

              <p>
               The book moves from first principles to practical
application, developing the theory and testing it
against its strongest objections and real-world cases
              </p>

            
            </div>

          </div>

        </div>

      </section>

      <section class="ssrn">

        <div class="container">

          <p class="eyebrow">
            FOUNDATIONAL PAPER
          </p>

          <h2>
            Read the SSRN Paper
          </h2>

          <p>
            The original paper presents the formal theorem and
            provides the theoretical foundation for the book
          </p>

          <a
            href={ssrnUrl}
            class="primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Open on SSRN
          </a>

        </div>

      </section>

    </main>

    <Footer />

  </body>
</html>
