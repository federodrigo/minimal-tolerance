---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const ssrnUrl =
  "https://papers.ssrn.com/sol3/papers.cfm?abstract_id=5984574";
---

<!doctype html>

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>
      A Theory of Minimal Tolerance | Minimal Tolerance
    </title>

    <meta
      name="description"
      content="A Theory of Minimal Tolerance by Federico Rodrigo examines coercion, political authority and the limits of state power."
    />

    <link
      rel="canonical"
      href="https://minimaltolerance.com/book"
    />
  </head>

  <body>

    <Header />

    <main>

      <section class="page-hero">

        <div class="container">

          <p class="eyebrow">
            THE BOOK
          </p>

          <h1>
            A Theory of Minimal Tolerance
          </h1>

        </div>

      </section>

      <section class="statement">

        <blockquote>
          The question is not whether coercive power is legitimate.
The question is how much of it can be tolerated
        </blockquote>

      </section>

      <section class="book">

        <div class="container">

          <div class="book-grid">

            <div>

              <img
                src="/images/book-cover.jpg"
                alt="Cover of A Theory of Minimal Tolerance by Federico Rodrigo"
              />

            </div>

            <div>

              <p class="eyebrow">
                ABOUT THE BOOK
              </p>

              <h2>
                A Theory of Minimal Tolerance
              </h2>

              <p>
               This forthcoming book develops the moral, economic, and institutional arguments underlying 
               the Theory of Minimal Tolerance. It examines the limits of coercion, the challenges of social 
               coordination, the incentives that drive the expansion of power, and the conditions 
                required to preserve a tolerable social order
              </p>

              <p>The book progresses from first principles to practical application, 
developing the framework and testing it against its most important objections and real-world cases
              </p>

            
            </div>

          </div>

        </div>

      </section>

      <section class="ssrn">

        <div class="container">

          <p class="eyebrow">
            FOUNDATIONAL PAPER
          </p>

          <h2>
            Read the SSRN Paper
          </h2>

          <p>
            The original paper presents the formal theorem and
            provides the theoretical foundation for the book
          </p>

          <a
            href={ssrnUrl}
            class="primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Open on SSRN
          </a>

        </div>

      </section>

    </main>

    <Footer />

  </body>
</html>
