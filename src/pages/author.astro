---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const ssrnUrl =
  "https://papers.ssrn.com/sol3/papers.cfm?abstract_id=5984574";
---

<!doctype html>

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>
      Autor | Minimal Tolerance
    </title>

    <meta
      name="description"
      content="Federico Rodrigo is an independent author and technology executive whose work examines coercion, political authority and the limits of state power."
    />

    <link
      rel="canonical"
      href="https://minimaltolerance.com/author"
    />
  </head>

  <body>

    <Header />

    <main>

      <section class="page-hero">

        <div class="container">

          <p class="eyebrow">
            THE AUTHOR
          </p>

          <h1>
            Federico Rodrigo
          </h1>

        </div>

      </section>

      <section class="statement">

        <blockquote>
          Every argument must survive its strongest objection
        </blockquote>

      </section>

      <section class="content-section">

        <div class="container">

          <p class="eyebrow">
            ABOUT
          </p>

          <h2>
            Independent author and technology executive
          </h2>

      <p>
  Federico "Fede" Rodrigo writes about power,
  legitimacy and coercion. His work explores the
  conditions under which state authority may be
  tolerated
</p>

<p>
  Political theory is a personal interest rather than a
  profession. Outside his writing, he works in
  technology leadership and executive management
</p>

        </div>

      </section>

<section class="content-section content-section-alt">

  <div class="container">

    <p class="eyebrow">
      CONTACT
    </p>

    <h2>
      Get in touch
    </h2>

    <p>
      Questions, objections and criticism are welcome
    </p>

    <p>
      <a href="mailto:fede@minimaltolerance.com">
        fede@minimaltolerance.com
      </a>
    </p>

  </div>

</section>






      <section class="ssrn">

        <div class="container">

          <p class="eyebrow">
            RESEARCH
          </p>

          <h2>
            The Theory of Minimal Tolerance
          </h2>

          <p>
            The foundational paper presents the formal theorem
            and the conditions under which state coercion may
            be tolerated.
          </p>

          <a
            href={ssrnUrl}
            class="primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Open on SSRN
          </a>

        </div>

      </section>

    </main>

    <Footer />

  </body>
</html>
